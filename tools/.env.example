# 复制为项目根目录的 .env 或本目录的 .env，填入真实值后运行 art_generator / 游戏密钥注入脚本（勿提交 .env）
# 根目录 .env 优先；本文件仅补充根目录未定义的键（与 art_generator 一致）。
PE_ART_API_KEY=
# 可选：网关根地址，默认 http://35.220.164.252:3888
# PE_API_BASE=http://35.220.164.252:3888
# 游戏内合铸（Gemini generateContent）若与 PE_ART 不同可单独写：
# HEZHU_API_KEY=
# HEZHU_ART_API_KEY=
# HEZHU_FUSION_ICON_API_KEY=
# 生图通道：openai（默认）| gemini | auto（先 OpenAI 式，403 时自动改走 generateContent）
# PE_IMAGE_BACKEND=auto
# PE_IMAGE_BACKEND=gemini
# PE_GEMINI_IMAGE_URL=http://35.220.164.252:3888/v1beta/models/imagen-4.0-ultra-generate-001:generateContent
