# 复制为项目根目录 .env（已 gitignore），或与 tools/.env 二选一；根目录变量优先于 tools/.env 中同名键。
# 生成浏览器用密钥脚本: node scripts/build-pe-env-js.js  -> 写入 js/pe-env.generated.js
# 若不生成文件，可自行向浏览器 localStorage 写入 pixel_eternal.api.* 键（见 js/config.js）。

# --- 与 tools/art_generator.py 一致（推荐只配这一项，游戏内合铸生图会复用）---
PE_ART_API_KEY=
# PE_API_BASE=http://35.220.164.252:3888

# --- 游戏合铸 / Gemini 通道可单独指定（可选）---
# HEZHU_API_KEY=
# HEZHU_ART_API_KEY=
# HEZHU_FUSION_ICON_API_KEY=
# HEZHU_API_BASE=http://35.220.164.252:3888
# PE_GEMINI_API_KEY=
